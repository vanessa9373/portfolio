        <mxCell id="55" value="Async Replication" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#F59E0B;strokeWidth=2;fontColor=#FCD34D;fontSize=12;fontStyle=1;endArrow=block;endFill=1;" edge="1" source="24" target="46" parent="1">
