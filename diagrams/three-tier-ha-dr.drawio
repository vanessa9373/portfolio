        <mxCell id="53" value="HTTPS Traffic" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#10B981;strokeWidth=3;fontColor=#6EE7B7;fontSize=12;fontStyle=1;endArrow=block;endFill=1;" edge="1" source="8" target="14" parent="1">
          <mxGeometry relative="1" as="geometry" />
