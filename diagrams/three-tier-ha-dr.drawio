        <mxCell id="54" value="Sync Replication" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#E53E3E;strokeWidth=3;fontColor=#FEB2B2;fontSize=12;fontStyle=1;endArrow=block;endFill=1;" edge="1" source="24" target="25" parent="1">
          <mxGeometry relative="1" as="geometry" />
