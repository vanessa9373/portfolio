  <diagram name="Three-Tier HA DR v3" id="va-arch-v3">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="4400" pageHeight="2900" math="0" shadow="0" background="#0F172A">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="2" value="Three-Tier Highly Available Web Application with Multi-Region Disaster Recovery" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontColor=#FFFFFF;fontSize=28;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="18" width="4200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="3" value="Primary Region: us-east-1  ·  3 Availability Zones  ·  99.99% Availability  ·  RTO &lt; 15 min  ·  RPO &lt; 5 min  ·  DR Warm Standby: us-west-2" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontColor=#94A3B8;fontSize=16;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="100" y="82" width="4200" height="36" as="geometry" />
        </mxCell>
        <mxCell id="4" value="Internet Users&#10;(Global Traffic)" style="rounded=2;whiteSpace=wrap;html=1;fillColor=#0a1628;strokeColor=#475569;strokeWidth=2;fontColor=#94A3B8;fontSize=16;fontStyle=1;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="1980" y="128" width="340" height="130" as="geometry" />
        </mxCell>
        <mxCell id="5" value="EDGE LAYER — Global (AWS Network)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#07111f;strokeColor=#1E3A5F;strokeWidth=4;fontColor=#7DD3FC;fontSize=15;fontStyle=1;verticalAlign=top;align=left;spacingTop=12;spacingLeft=16;" vertex="1" parent="1">
          <mxGeometry x="40" y="295" width="4320" height="290" as="geometry" />
        </mxCell>
        <mxCell id="6" value="Route 53&#10;• Failover Routing Policy&#10;• Health Check: every 10s&#10;• DNS TTL: 60 seconds&#10;• Detects failure in ~30s" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0a1628;strokeColor=#2D4A8A;strokeWidth=2;fontColor=#E2E8F0;fontSize=14;fontStyle=0;arcSize=8;verticalAlign=top;align=left;spacingTop=10;spacingLeft=12;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="685" y="325" width="460" height="240" as="geometry" />
        </mxCell>
        <mxCell id="7" value="CloudFront CDN&#10;• 450+ Global Edge Locations&#10;• 2 behaviors: static + dynamic&#10;• Origin Access Control (OAC)&#10;• TLS 1.2+ enforced" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0a1628;strokeColor=#2D4A8A;strokeWidth=2;fontColor=#E2E8F0;fontSize=14;fontStyle=0;arcSize=8;verticalAlign=top;align=left;spacingTop=10;spacingLeft=12;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="1199" y="325" width="460" height="240" as="geometry" />
        </mxCell>
        <mxCell id="8" value="AWS WAF&#10;• OWASP Top 10 Rules&#10;• SQL Injection Protection&#10;• Rate Limit: 2,000 req/5min&#10;• IP Reputation List" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a0808;strokeColor=#9B2C2C;strokeWidth=2;fontColor=#E2E8F0;fontSize=14;fontStyle=0;arcSize=8;verticalAlign=top;align=left;spacingTop=10;spacingLeft=12;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="1713" y="325" width="460" height="240" as="geometry" />
        </mxCell>
        <mxCell id="9" value="ACM&#10;• TLS Certificate — Auto-Renewal&#10;• CloudFront cert (us-east-1)&#10;• ALB cert per region&#10;• No manual rotation needed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#041a08;strokeColor=#276749;strokeWidth=2;fontColor=#E2E8F0;fontSize=14;fontStyle=0;arcSize=8;verticalAlign=top;align=left;spacingTop=10;spacingLeft=12;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="2227" y="325" width="460" height="240" as="geometry" />
        </mxCell>
        <mxCell id="10" value="Shield Standard&#10;• DDoS Protection&#10;• Included with CloudFront&#10;• Layer 3/4 protection&#10;• No additional cost" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a0808;strokeColor=#9B2C2C;strokeWidth=2;fontColor=#E2E8F0;fontSize=14;fontStyle=0;arcSize=8;verticalAlign=top;align=left;spacingTop=10;spacingLeft=12;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="2741" y="325" width="460" height="240" as="geometry" />
        </mxCell>
        <mxCell id="11" value="Internet Gateway&#10;• Attached to Primary VPC&#10;• Enables internet access&#10;• 1 per VPC (redundant by design)&#10;• Handles edge to VPC routing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#07111f;strokeColor=#334155;strokeWidth=2;fontColor=#E2E8F0;fontSize=14;fontStyle=0;arcSize=8;verticalAlign=top;align=left;spacingTop=10;spacingLeft=12;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="3255" y="325" width="460" height="240" as="geometry" />
        </mxCell>
        <mxCell id="12" value="PRIMARY VPC — us-east-1   ·   CIDR: 10.0.0.0/16" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#06111e;strokeColor=#1E40AF;strokeWidth=5;fontColor=#93C5FD;fontSize=17;fontStyle=1;verticalAlign=top;align=left;spacingTop=12;spacingLeft=16;" vertex="1" parent="1">
          <mxGeometry x="40" y="600" width="2900" height="2020" as="geometry" />
        </mxCell>
        <mxCell id="13" value="PUBLIC SUBNETS   us-east-1a  ·  us-east-1b  ·  us-east-1c   |   CIDR: 10.0.1-3.0/24" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#061a0c;strokeColor=#22543D;strokeWidth=3;fontColor=#68D391;fontSize=15;fontStyle=1;verticalAlign=top;align=left;spacingTop=12;spacingLeft=16;" vertex="1" parent="1">
          <mxGeometry x="70" y="648" width="2840" height="320" as="geometry" />
        </mxCell>
        <mxCell id="14" value="Application Load Balancer&#10;• HTTPS:443 to EC2 target group&#10;• HTTP:80 redirects to HTTPS&#10;• Cross-Zone Load Balancing: ON&#10;• Sec Group: CloudFront prefix list ONLY&#10;• Health check: /health (200 OK)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0a2a10;strokeColor=#22543D;strokeWidth=2;fontColor=#E2E8F0;fontSize=14;fontStyle=0;arcSize=8;verticalAlign=top;align=left;spacingTop=10;spacingLeft=12;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="100" y="696" width="580" height="250" as="geometry" />
        </mxCell>
        <mxCell id="15" value="NAT Gateway — AZ-a&#10;• Elastic IP attached&#10;• $0.045/hr + $0.045/GB&#10;• AZ-local outbound only&#10;• No cross-AZ charges" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0a2a10;strokeColor=#22543D;strokeWidth=2;fontColor=#E2E8F0;fontSize=14;fontStyle=0;arcSize=8;verticalAlign=top;align=left;spacingTop=10;spacingLeft=12;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="720" y="696" width="360" height="250" as="geometry" />
        </mxCell>
        <mxCell id="16" value="NAT Gateway — AZ-b&#10;• Elastic IP attached&#10;• Eliminates AZ-failure risk&#10;• Independent from AZ-a&#10;• Private subnets route here" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0a2a10;strokeColor=#22543D;strokeWidth=2;fontColor=#E2E8F0;fontSize=14;fontStyle=0;arcSize=8;verticalAlign=top;align=left;spacingTop=10;spacingLeft=12;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="1120" y="696" width="360" height="250" as="geometry" />
        </mxCell>
        <mxCell id="17" value="NAT Gateway — AZ-c&#10;• Elastic IP attached&#10;• 3 NAT GWs = HA pattern&#10;• Never use 1 shared NAT GW&#10;• Prevents single-AZ outage" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0a2a10;strokeColor=#22543D;strokeWidth=2;fontColor=#E2E8F0;fontSize=14;fontStyle=0;arcSize=8;verticalAlign=top;align=left;spacingTop=10;spacingLeft=12;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="1520" y="696" width="360" height="250" as="geometry" />
        </mxCell>
        <mxCell id="18" value="PRIVATE APP SUBNETS   us-east-1a  ·  us-east-1b  ·  us-east-1c   |   CIDR: 10.0.11-13.0/24   |   Outbound: NAT Gateway only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0e0a28;strokeColor=#553C9A;strokeWidth=3;fontColor=#C3B1E1;fontSize=15;fontStyle=1;verticalAlign=top;align=left;spacingTop=12;spacingLeft=16;" vertex="1" parent="1">
          <mxGeometry x="70" y="1020" width="2840" height="360" as="geometry" />
        </mxCell>
        <mxCell id="19" value="Auto Scaling Group:  min=2  ·  desired=3  ·  max=10  ·  Scale trigger: ALBRequestCountPerTarget = 1,000  ·  Cooldown: 300s" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontColor=#C3B1E1;fontSize=13;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="90" y="1046" width="2800" height="30" as="geometry" />
        </mxCell>
        <mxCell id="20" value="EC2 — us-east-1a&#10;• Instance: t3.medium&#10;• IMDSv2 required (SSRF blocked)&#10;• IAM Role — no long-term keys&#10;• SSM Agent (no SSH needed)&#10;• Connects via ALB only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a0f3a;strokeColor=#553C9A;strokeWidth=2;fontColor=#E2E8F0;fontSize=14;fontStyle=0;arcSize=8;verticalAlign=top;align=left;spacingTop=10;spacingLeft=12;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="100" y="1080" width="540" height="280" as="geometry" />
        </mxCell>
        <mxCell id="21" value="EC2 — us-east-1b&#10;• Instance: t3.medium&#10;• Same AMI as AZ-a&#10;• Auto-replaced if unhealthy&#10;• IAM Role — no long-term keys&#10;• Stateless (sessions in Redis)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a0f3a;strokeColor=#553C9A;strokeWidth=2;fontColor=#E2E8F0;fontSize=14;fontStyle=0;arcSize=8;verticalAlign=top;align=left;spacingTop=10;spacingLeft=12;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="700" y="1080" width="540" height="280" as="geometry" />
        </mxCell>
        <mxCell id="22" value="EC2 — us-east-1c&#10;• Instance: t3.medium&#10;• ASG maintains desired=3&#10;• Rolling deploy: 20% min healthy&#10;• Logs to CloudWatch Log Group&#10;• Metrics to CloudWatch dashboard" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a0f3a;strokeColor=#553C9A;strokeWidth=2;fontColor=#E2E8F0;fontSize=14;fontStyle=0;arcSize=8;verticalAlign=top;align=left;spacingTop=10;spacingLeft=12;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="1300" y="1080" width="540" height="280" as="geometry" />
        </mxCell>
        <mxCell id="23" value="PRIVATE DB SUBNETS   us-east-1a  ·  us-east-1b  ·  us-east-1c   |   CIDR: 10.0.21-23.0/24   |   DB-SG: port 3306 from App-SG ONLY" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a0606;strokeColor=#9B2C2C;strokeWidth=3;fontColor=#FEB2B2;fontSize=15;fontStyle=1;verticalAlign=top;align=left;spacingTop=12;spacingLeft=16;" vertex="1" parent="1">
          <mxGeometry x="70" y="1440" width="2840" height="360" as="geometry" />
        </mxCell>
        <mxCell id="24" value="RDS MySQL — PRIMARY&#10;• Instance: db.r6g.large (Graviton2)&#10;• Storage: 500 GB gp3 auto-scales 2TB&#10;• KMS CMK encrypted at rest&#10;• Auto Backup: 7-day retention&#10;• Performance Insights: enabled" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#280a0a;strokeColor=#9B2C2C;strokeWidth=2;fontColor=#E2E8F0;fontSize=14;fontStyle=0;arcSize=8;verticalAlign=top;align=left;spacingTop=10;spacingLeft=12;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="100" y="1486" width="590" height="290" as="geometry" />
        </mxCell>
        <mxCell id="25" value="RDS MySQL — STANDBY&#10;• Synchronous replication to primary&#10;• Different AZ from primary&#10;• Auto Failover: 60-120 seconds&#10;• Passive — not readable (no read scaling)&#10;• DNS flip on failover — no app change" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#280a0a;strokeColor=#9B2C2C;strokeWidth=2;fontColor=#E2E8F0;fontSize=14;fontStyle=0;arcSize=8;verticalAlign=top;align=left;spacingTop=10;spacingLeft=12;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="740" y="1486" width="570" height="290" as="geometry" />
        </mxCell>
        <mxCell id="26" value="ElastiCache Redis — PRIMARY&#10;• Instance: cache.t4g.medium (Graviton2)&#10;• Port 6379 — Cache-SG: App-SG only&#10;• Session storage (stateless EC2)&#10;• Query result cache (5-60 min TTL)&#10;• Rate limiting counters (atomic incr)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#281400;strokeColor=#DD6B20;strokeWidth=2;fontColor=#E2E8F0;fontSize=14;fontStyle=0;arcSize=8;verticalAlign=top;align=left;spacingTop=10;spacingLeft=12;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="1370" y="1486" width="560" height="290" as="geometry" />
        </mxCell>
        <mxCell id="27" value="ElastiCache — REPLICA&#10;• Different AZ from primary&#10;• Auto Failover: enabled&#10;• Replica reads offload primary&#10;• Same cluster endpoint (transparent)&#10;• Cache-SG: port 6379 from App-SG only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#281400;strokeColor=#DD6B20;strokeWidth=2;fontColor=#E2E8F0;fontSize=14;fontStyle=0;arcSize=8;verticalAlign=top;align=left;spacingTop=10;spacingLeft=12;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="1990" y="1486" width="500" height="290" as="geometry" />
        </mxCell>
        <mxCell id="29" value="SHARED SERVICES — Security  ·  Storage  ·  Observability  ·  CI/CD" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#050c1e;strokeColor=#1E3A5F;strokeWidth=3;fontColor=#7DD3FC;fontSize=15;fontStyle=1;verticalAlign=top;align=left;spacingTop=12;spacingLeft=16;" vertex="1" parent="1">
          <mxGeometry x="70" y="1870" width="2840" height="700" as="geometry" />
        </mxCell>
        <mxCell id="30" value="S3 — Static Assets&#10;• SSE-KMS encryption at rest&#10;• Versioning: enabled&#10;• CloudFront OAC only valid origin&#10;• Lifecycle: Glacier after 90 days&#10;• CRR to us-west-2 replica bucket" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#041014;strokeColor=#1E3A5F;strokeWidth=2;fontColor=#E2E8F0;fontSize=14;fontStyle=0;arcSize=8;verticalAlign=top;align=left;spacingTop=10;spacingLeft=12;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="90" y="1925" width="490" height="240" as="geometry" />
        </mxCell>
        <mxCell id="31" value="Secrets Manager&#10;• Stores: DB credentials, API keys&#10;• 30-day automatic rotation&#10;• App retrieves at startup (no hardcoding)&#10;• KMS CMK encrypted&#10;• Audit: every retrieval to CloudTrail" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a0a08;strokeColor=#9B2C2C;strokeWidth=2;fontColor=#E2E8F0;fontSize=14;fontStyle=0;arcSize=8;verticalAlign=top;align=left;spacingTop=10;spacingLeft=12;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="634" y="1925" width="490" height="240" as="geometry" />
        </mxCell>
        <mxCell id="32" value="KMS (Customer Managed Key)&#10;• Encrypts: RDS, S3, ElastiCache&#10;• Also: SSM SecureString, Secrets Mgr&#10;• Key rotation: enabled (annual)&#10;• All usage logged to CloudTrail&#10;• Separate CMK per data classification" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a0a08;strokeColor=#9B2C2C;strokeWidth=2;fontColor=#E2E8F0;fontSize=14;fontStyle=0;arcSize=8;verticalAlign=top;align=left;spacingTop=10;spacingLeft=12;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="1178" y="1925" width="490" height="240" as="geometry" />
        </mxCell>
        <mxCell id="33" value="SSM — Systems Manager&#10;• Parameter Store: config values&#10;• Session Manager: shell access&#10;• No SSH open — no bastion host&#10;• Patch Manager: OS updates&#10;• Run Command: remote execution" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#050c1e;strokeColor=#1E3A5F;strokeWidth=2;fontColor=#E2E8F0;fontSize=14;fontStyle=0;arcSize=8;verticalAlign=top;align=left;spacingTop=10;spacingLeft=12;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="1722" y="1925" width="490" height="240" as="geometry" />
        </mxCell>
        <mxCell id="34" value="CloudWatch&#10;• Metrics: ALB, EC2, RDS, Cache&#10;• Alarms: CPU, latency, unhealthy hosts&#10;• Logs: 90-day retention + S3 archive&#10;• Dashboards: ops + cost&#10;• Anomaly Detection enabled" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#050c1e;strokeColor=#1E3A5F;strokeWidth=2;fontColor=#E2E8F0;fontSize=14;fontStyle=0;arcSize=8;verticalAlign=top;align=left;spacingTop=10;spacingLeft=12;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="2266" y="1925" width="490" height="240" as="geometry" />
        </mxCell>
        <mxCell id="35" value="GuardDuty&#10;• ML-based threat detection&#10;• Analyzes: VPC Flow, CloudTrail, DNS&#10;• High severity to Lambda auto-isolate&#10;• Findings to EventBridge to SNS page&#10;• Zero config, always-on" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a0808;strokeColor=#9B2C2C;strokeWidth=2;fontColor=#E2E8F0;fontSize=14;fontStyle=0;arcSize=8;verticalAlign=top;align=left;spacingTop=10;spacingLeft=12;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="90" y="2210" width="490" height="240" as="geometry" />
        </mxCell>
        <mxCell id="36" value="CloudTrail&#10;• All API events — all regions&#10;• S3 destination: MFA-Delete + Lock&#10;• CloudTrail Lake: SQL query interface&#10;• DenyCloudTrailDisable SCP covers this&#10;• Immutable audit trail" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#050c1e;strokeColor=#1E3A5F;strokeWidth=2;fontColor=#E2E8F0;fontSize=14;fontStyle=0;arcSize=8;verticalAlign=top;align=left;spacingTop=10;spacingLeft=12;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="634" y="2210" width="490" height="240" as="geometry" />
        </mxCell>
        <mxCell id="37" value="AWS Config&#10;• Continuous compliance audit&#10;• CIS AWS Benchmark rules&#10;• Auto-remediation: SSM runbooks&#10;• Rules: IMDSv2, S3 public block, etc.&#10;• Non-compliant: alert + fix" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#050c1e;strokeColor=#1E3A5F;strokeWidth=2;fontColor=#E2E8F0;fontSize=14;fontStyle=0;arcSize=8;verticalAlign=top;align=left;spacingTop=10;spacingLeft=12;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="1178" y="2210" width="490" height="240" as="geometry" />
        </mxCell>
        <mxCell id="38" value="AWS Backup&#10;• Centralized backup policy&#10;• Covers: RDS, EFS, EBS, DynamoDB&#10;• Cross-region copy to us-west-2&#10;• Vault Lock (WORM protection)&#10;• 35-day retention" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#041014;strokeColor=#1E3A5F;strokeWidth=2;fontColor=#E2E8F0;fontSize=14;fontStyle=0;arcSize=8;verticalAlign=top;align=left;spacingTop=10;spacingLeft=12;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="1722" y="2210" width="490" height="240" as="geometry" />
        </mxCell>
        <mxCell id="39" value="CodePipeline&#10;• Source to Build to Test to Deploy&#10;• Rolling deployment (20% min healthy)&#10;• Automatic rollback on failure&#10;• CodeDeploy deregisters from ALB first&#10;• Blue/green optional upgrade path" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a0a00;strokeColor=#D97706;strokeWidth=2;fontColor=#E2E8F0;fontSize=14;fontStyle=0;arcSize=8;verticalAlign=top;align=left;spacingTop=10;spacingLeft=12;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="2266" y="2210" width="490" height="240" as="geometry" />
        </mxCell>
        <mxCell id="40" value="Security Group Chain:  ALB-SG (443 from CloudFront prefix list only)  to  App-SG (8080 from ALB-SG only)  to  DB-SG (3306 from App-SG only)  to  Cache-SG (6379 from App-SG only)" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontColor=#FEB2B2;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="2482" width="2820" height="44" as="geometry" />
        </mxCell>
        <mxCell id="41" value="VPC Gateway Endpoints (FREE): S3, DynamoDB  ·  Interface Endpoints: SSM, Secrets Manager, ECR  —  Eliminates NAT Gateway charges for AWS service traffic" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontColor=#7DD3FC;fontSize=13;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="80" y="2528" width="2820" height="34" as="geometry" />
        </mxCell>
        <mxCell id="42" value="DR REGION — us-west-2 (Oregon)   ·   WARM STANDBY   ·   VPC: 10.1.0.0/16" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0e0600;strokeColor=#9C4221;strokeWidth=5;fontColor=#FBBF24;fontSize=17;fontStyle=1;verticalAlign=top;align=left;spacingTop=12;spacingLeft=16;" vertex="1" parent="1">
          <mxGeometry x="2980" y="600" width="1380" height="2020" as="geometry" />
        </mxCell>
        <mxCell id="43" value="STRATEGY: Warm Standby&#10;• RTO: &lt; 15 minutes&#10;• RPO: &lt; 5 minutes&#10;• Cost: ~$200/mo (~30% of primary)&#10;• Failover: Automated via Route 53&#10;• Failback: Planned manual operation&#10;• Quarterly DR drill: required" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2a1000;strokeColor=#9C4221;strokeWidth=2;fontColor=#FCD34D;fontSize=14;fontStyle=0;arcSize=8;verticalAlign=top;align=left;spacingTop=10;spacingLeft=12;" vertex="1" parent="1">
          <mxGeometry x="3010" y="646" width="1320" height="230" as="geometry" />
        </mxCell>
        <mxCell id="44" value="ALB (DR)&#10;• Scaled-down: min=1 desired=1&#10;• Ready to scale instantly&#10;• Same Target Group config as primary&#10;• Health check: /health (200 OK)&#10;• Accepts traffic on Route 53 failover" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0a2a10;strokeColor=#22543D;strokeWidth=2;fontColor=#E2E8F0;fontSize=14;fontStyle=0;arcSize=8;verticalAlign=top;align=left;spacingTop=10;spacingLeft=12;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="3010" y="910" width="1320" height="260" as="geometry" />
        </mxCell>
        <mxCell id="45" value="EC2 ASG (DR)&#10;• Instance: t3.small (scaled down)&#10;• min=1, desired=1, max=10&#10;• Same AMI — matches primary&#10;• Ready to scale: 3-5 min&#10;• IMDSv2 + IAM Role + SSM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a0f3a;strokeColor=#553C9A;strokeWidth=2;fontColor=#E2E8F0;fontSize=14;fontStyle=0;arcSize=8;verticalAlign=top;align=left;spacingTop=10;spacingLeft=12;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="3010" y="1210" width="1320" height="260" as="geometry" />
        </mxCell>
        <mxCell id="46" value="RDS Read Replica to PROMOTED&#10;• Async replication from primary&#10;• Lag: typically &lt; 5 min (RPO target)&#10;• Promote to standalone on failover&#10;• After failover: becomes new primary&#10;• CRR: S3 data synced automatically" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#280a0a;strokeColor=#9B2C2C;strokeWidth=2;fontColor=#E2E8F0;fontSize=14;fontStyle=0;arcSize=8;verticalAlign=top;align=left;spacingTop=10;spacingLeft=12;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="3010" y="1510" width="1320" height="290" as="geometry" />
        </mxCell>
        <mxCell id="47" value="ElastiCache (DR)&#10;• Standalone cluster (no replication)&#10;• Starts empty — cold cache on failover&#10;• Session data: re-auth required&#10;• Cache warm-up: ~2-5 min after failover&#10;• Acceptable for DR scenario" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#281400;strokeColor=#DD6B20;strokeWidth=2;fontColor=#E2E8F0;fontSize=14;fontStyle=0;arcSize=8;verticalAlign=top;align=left;spacingTop=10;spacingLeft=12;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="3010" y="1850" width="1320" height="260" as="geometry" />
        </mxCell>
        <mxCell id="48" value="S3 Replica Bucket (us-west-2)&#10;• CRR replicates from primary bucket&#10;• Replication lag: &lt; 15 min typically&#10;• Same KMS encryption (cross-region key)&#10;• Lifecycle rules mirror primary&#10;• Read-only via CloudFront OAC" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#041014;strokeColor=#1E3A5F;strokeWidth=2;fontColor=#E2E8F0;fontSize=14;fontStyle=0;arcSize=8;verticalAlign=top;align=left;spacingTop=10;spacingLeft=12;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="3010" y="2160" width="1320" height="240" as="geometry" />
        </mxCell>
        <mxCell id="49" value="DR FAILOVER SEQUENCE:&#10;1. Route 53 health check fails (30s)  to  2. DNS flips to DR ALB  to  3. Traffic hits DR ALB + EC2  to  4. EC2 promotes RDS Read Replica  to  5. ASG scales up  to  6. Full capacity in &lt;15 min" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a0800;strokeColor=#9C4221;strokeWidth=2;fontColor=#FBBF24;fontSize=13;fontStyle=0;verticalAlign=middle;align=left;spacingLeft=12;" vertex="1" parent="1">
          <mxGeometry x="2980" y="2450" width="1380" height="120" as="geometry" />
        </mxCell>
        <mxCell id="50" value="DNS Resolution" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#3B82F6;strokeWidth=3;fontColor=#93C5FD;fontSize=12;fontStyle=1;endArrow=block;endFill=1;" edge="1" source="4" target="6" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="51" value="CDN Request" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#3B82F6;strokeWidth=3;fontColor=#93C5FD;fontSize=12;fontStyle=1;endArrow=block;endFill=1;" edge="1" source="6" target="7" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="52" value="WAF Filter" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#EF4444;strokeWidth=3;fontColor=#FCA5A5;fontSize=12;fontStyle=1;endArrow=block;endFill=1;" edge="1" source="7" target="8" parent="1">
          <mxGeometry relative="1" as="geometry" />
