        <mxCell id="e_ct_sh" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#DD344C;" edge="1" source="ct" target="sh" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
