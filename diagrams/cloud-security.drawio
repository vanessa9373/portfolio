        </mxCell>
        <mxCell id="lambda_r" value="Lambda&#xa;(Auto-remediation:&#xa;isolate EC2 on&#xa;GuardDuty finding)" style="outlineConnect=0;fontColor=#232F3E;gradientColor=none;strokeColor=none;fillColor=#E7157B;labelBackgroundColor=#ffffff;align=center;html=1;fontSize=11;fontStyle=0;aspect=fixed;verticalLabelPosition=bottom;verticalAlign=top;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda_function;" vertex="1" parent="1">
          <mxGeometry x="1370" y="280" width="60" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="eb" value="EventBridge&#xa;(Security Hub → Lambda&#xa;rule trigger)" style="outlineConnect=0;fontColor=#232F3E;gradientColor=none;strokeColor=none;fillColor=#8C4FFF;labelBackgroundColor=#ffffff;align=center;html=1;fontSize=11;fontStyle=0;aspect=fixed;verticalLabelPosition=bottom;verticalAlign=top;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.eventbridge;" vertex="1" parent="1">
          <mxGeometry x="1250" y="280" width="60" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="e_sh_cw" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#DD344C;" edge="1" source="sh" target="cw" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_cw_sns" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#E7157B;" edge="1" source="cw" target="sns" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_sh_eb" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#8C4FFF;" edge="1" source="sh" target="eb" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_eb_lam" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#8C4FFF;" edge="1" source="eb" target="lambda_r" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- LEGEND -->
        <mxCell id="80" value="&lt;b&gt;Perimeter&lt;/b&gt; — WAF OWASP rules block SQLi / XSS at edge; CloudFront enforces HTTPS; Security Groups use least-privilege ingress (no 0.0.0.0/0 on SSH)&#xa;&lt;b&gt;Identity&lt;/b&gt; — IAM Permission Boundaries + SCPs prevent privilege escalation; IMDSv2 blocks SSRF; Secrets Manager auto-rotates credentials every 30 days&#xa;&lt;b&gt;Detection → Response&lt;/b&gt; — GuardDuty + Config + Inspector feed Security Hub; EventBridge triggers Lambda to auto-isolate compromised EC2 instances within seconds" style="text;html=1;strokeColor=#DD344C;fillColor=#FFEBEE;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
