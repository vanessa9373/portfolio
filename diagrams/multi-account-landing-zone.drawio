        <!-- LEGEND -->
        <mxCell id="80" value="&lt;b&gt;Security&lt;/b&gt; — SCPs are the first line of guardrails; GuardDuty delegated admin aggregates threat findings across all accounts into Security Hub&#xa;&lt;b&gt;Reliability&lt;/b&gt; — Transit Gateway hub-and-spoke with non-overlapping CIDRs; single network account owns routing tables&#xa;&lt;b&gt;Operational Excellence&lt;/b&gt; — IAM Identity Center (one identity source, SAML 2.0) | CloudTrail centralised to immutable Log Archive account with KMS CMK encryption" style="text;html=1;strokeColor=#8C4FFF;fillColor=#F4ECFF;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
