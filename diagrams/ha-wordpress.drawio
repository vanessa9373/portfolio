        <!-- LEGEND -->
        <mxCell id="21" value="&lt;b&gt;Well-Architected: Reliability&lt;/b&gt; — Multi-AZ across 3 AZs, RDS failover &lt;2min, Auto Scaling on CPU/request metrics&#xa;&lt;b&gt;Security&lt;/b&gt; — WAF (OWASP/SQLi), KMS CMK, IMDSv2, SSM (no SSH), S3 OAC&#xa;&lt;b&gt;Cost&lt;/b&gt; — CloudFront edge caching reduces origin load ~60%  |  ElastiCache offloads DB reads" style="text;html=1;strokeColor=#8C4FFF;fillColor=#F4ECFF;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
