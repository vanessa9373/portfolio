        <!-- LEGEND -->
        <mxCell id="80" value="&lt;b&gt;Cost&lt;/b&gt; — Zero server costs: GitHub Pages (free CDN), Firebase Auth Spark plan (free tier), Gemini 2.0 Flash API (low per-token cost); &lt;$5/month at scale&#xa;&lt;b&gt;Performance&lt;/b&gt; — React code-split + tree-shaken bundle &lt;150 KB gzip; served from global CDN edge (sub-50ms TTFB)&#xa;&lt;b&gt;Security&lt;/b&gt; — Firebase JWT validation (RS256); API key scoped to Gemini only; HTTPS enforced by GitHub Pages; no backend = no SQL injection surface" style="text;html=1;strokeColor=#8C4FFF;fillColor=#F4ECFF;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
